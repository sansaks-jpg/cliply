{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cliply",
  "version": "0.1.1",
  "identifier": "com.cliply.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3107",
    "beforeDevCommand": "pnpm --prefix ../ dev",
    "beforeBuildCommand": "pnpm --prefix ../ build"
  },
  "app": {
    "windows": [
      {
        "title": "Cliply",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../backend/dist/cliply_server.exe": "backend/cliply_server.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/sansaks-jpg/cliply/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1ODJDOTkzNjlFNDUyMDIKUldRQ1V1UnBrOG1DOVVkZ2M5L09BR013SXlDRXBzL1BIYTRWS2hVUlR0dWI3Z1Bqcy83Q0ZIdE4K"
    }
  }
}
