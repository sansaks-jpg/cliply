# API mode (default)
MUAPI_API_KEY=your_muapi_key_here

# Local mode (--mode local)
LLM_PROVIDER=openai           # openai, gemini, or anthropic
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=auto
LOCAL_OUTPUT_DIR=output

# Pipeline defaults
NUM_CLIPS_DEFAULT=5           # default number of clips per task
DOWNLOAD_FORMAT=1080          # preferred download resolution
HIGHLIGHT_MAX_WORKERS=8       # parallel workers for highlight ranking

# Storage & fonts
STORAGE_DIR=./storage         # video/task temp storage
FONTS_DIR=./fonts             # subtitle font files

# Redis
REDIS_URL=redis://localhost:6379

# Server
BACKEND_PORT=8003             # FastAPI server port
CORS_ORIGINS=http://localhost:3107,http://tauri.localhost,tauri://localhost
